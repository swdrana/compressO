{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "editor.defaultFormatter": "biomejs.biome",
  "cSpell.words": [
    "appimage",
    "compresso",
    "Deflaters",
    "Exif",
    "FFPROBE",
    "ghostscript",
    "gifsicle",
    "gifski",
    "heroui",
    "imagequant",
    "jpegoptim",
    "matroska",
    "msvideo",
    "nsis",
    "oxipng",
    "pixmap",
    "pngquant",
    "resvg",
    "skia",
    "svgcleaner",
    "tauri",
    "Triggerer",
    "Unlisten",
    "usvg",
    "valtio",
    "vtracer"
  ],
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[svg]": {
    "editor.defaultFormatter": "jock.svg"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "workbench.colorCustomizations": {
    "statusBarItem.warningBackground": "#e2326c",
    "statusBarItem.warningForeground": "#ffffff",
    "statusBarItem.warningHoverBackground": "#e2326c",
    "statusBarItem.warningHoverForeground": "#ffffff90",
    "statusBarItem.remoteBackground": "#ef3f79",
    "statusBarItem.remoteForeground": "#ffffff",
    "statusBarItem.remoteHoverBackground": "#fc4c86",
    "statusBarItem.remoteHoverForeground": "#ffffff90",
    "statusBar.background": "#e2326c",
    "statusBar.foreground": "#ffffff",
    "statusBar.border": "#e2326c",
    "statusBar.debuggingBackground": "#e2326c",
    "statusBar.debuggingForeground": "#ffffff",
    "statusBar.debuggingBorder": "#e2326c",
    "statusBar.noFolderBackground": "#e2326c",
    "statusBar.noFolderForeground": "#ffffff",
    "statusBar.noFolderBorder": "#e2326c",
    "statusBar.prominentBackground": "#e2326c",
    "statusBar.prominentForeground": "#ffffff",
    "statusBar.prominentHoverBackground": "#e2326c",
    "statusBar.prominentHoverForeground": "#ffffff90",
    "focusBorder": "#e2326c99",
    "progressBar.background": "#e2326c",
    "textLink.foreground": "#ff72ac",
    "textLink.activeForeground": "#ff7fb9",
    "selection.background": "#d5255f",
    "list.highlightForeground": "#e2326c",
    "list.focusAndSelectionOutline": "#e2326c99",
    "button.background": "#e2326c",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#ef3f79",
    "tab.activeBorderTop": "#ef3f79",
    "pickerGroup.foreground": "#ef3f79",
    "list.activeSelectionBackground": "#e2326c4d",
    "panelTitle.activeBorder": "#ef3f79",
    "activityBar.activeBorder": "#e2326c",
    "activityBarBadge.foreground": "#ffffff",
    "activityBarBadge.background": "#e2326c"
  },
  "window.title": "compressO"
}
